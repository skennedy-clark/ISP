# -------------------------
# 1) Python build & caches
# -------------------------
__pycache__/
*.py[cod]
*.so
*.pyd
*.dylib

# -------------------------
# 2) Virtual environments
# -------------------------
# You have a venv/ checked in at the repo root — ignore it
venv/
.env/
.venv/
ENV/
env/
pip-wheel-metadata/

# -------------------------
# 3) OS and editor cruft
# -------------------------
# macOS / Windows
.DS_Store
Thumbs.db
desktop.ini
# JetBrains / VS Code, etc.
.idea/
.vscode/
*.iml

# -------------------------
# 4) Data & databases (large/derived)
# -------------------------
# SQLite and companions
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
*.db-journal
*.bak

# Zips/archives and large inputs/outputs
*.zip
*.7z
*.tar
*.tar.gz
*.gz


# Images exported from analysis (keep figures only if you explicitly add)
*.png
*.svg
*.jpg
*.jpeg
*.tif
*.tiff

# -------------------------
# 5) Project-specific bulky folders
# -------------------------
# Historical snapshots, example bundles, and generated results
db/
ISP2026 data for adding to DB/
# Subtree with many scenario images (coal capacity/UF PDFs)
archive/shaochen_db/GETRC/
# CSV conversions of XLSX "exceptions"
archive/shaochen_db/exception/
# Example datasets and GenX results (reproducible)
archive/shaochen_db/example_files/
# Any results folders if they appear under archive/*
archive/**/results/

# -------------------------
# 6) Keep lists for small curated inputs & code
# -------------------------
# We WANT these tracked:
!README.md
!**/*.py
!**/*.yml
!**/*.yaml
!**/*.txt
!**/*.md
# Keep your curated input CSVs that drive DB builds
!archive/shaochen_db/input_csv/
!archive/shaochen_db/input_csv/**/*
# If you maintain a small technology/name map CSV, keep it:
!**/name_map_technology.csv

# If you must keep a rendered figure next to code, explicitly unignore it:
# !Figure_1.png

# -------------------------
# 7) OneDrive sync junk (if it appears)
# -------------------------
*.lnk
~$*
